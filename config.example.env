# LM Benchmarks configuration
# Copy to .env and customize

# Serving
# ENGINE=vllm
# PORT=8080
# SERVER_TIMEOUT=300
# GPU_MEMORY_THRESHOLD=0.9

# Benchmark defaults
# DATASET=random
# NUM_PROMPTS=100
# INPUT_LEN=8192
# OUTPUT_LEN=1024
# REQUEST_RATE=8.0
# TIMEOUT=300

# Results
# RESULTS_DIR=./results
# PLOT_FORMAT=png
# PLOT_DPI=150
